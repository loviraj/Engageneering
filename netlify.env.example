# Copy to .env in repo root for: netlify dev
# (Netlify CLI loads these for serverless functions only — not sent to the browser)

RAZORPAY_KEY_ID=rzp_test_your_key_id
RAZORPAY_KEY_SECRET=your_razorpay_secret

# Optional — used by aria-moderate on index.html demo
ANTHROPIC_API_KEY=your_anthropic_key

# build-config.sh also reads these if you run a Netlify-style build locally:
SUPA_URL=https://YOUR_PROJECT.supabase.co
SUPA_ANON=your_supabase_anon_key
